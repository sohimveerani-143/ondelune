rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pairing docs: any signed-in (anonymous) user can read/create a pending
    // pairing, and only the person opening the link can consume it — exactly once.
    match /pairings/{pairingId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.creatorUid == request.auth.uid
                    && request.resource.data.status == 'pending';

      allow update: if request.auth != null
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'paired'
                    && request.resource.data.joinerUid == request.auth.uid;
    }

    // Rooms: only the two paired members may read or write anything inside.
    match /rooms/{roomId} {
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.memberUids;

      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.memberUids;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
                            && request.auth.uid in
                               get(/databases/$(database)/documents/rooms/$(roomId)).data.memberUids;
      }
    }
  }
}
